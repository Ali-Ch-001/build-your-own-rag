# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Local-only identity. Set AUTH_DISABLED=false outside local development.
AUTH_DISABLED=true
DEV_TENANT_ID=00000000-0000-0000-0000-000000000001
DEV_SUBJECT_ID=local-developer
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ALGORITHMS=RS256

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://rag:rag-local-password@localhost:5432/rag
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Object storage (MinIO locally, S3 in AWS)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin-local-only
S3_QUARANTINE_BUCKET=rag-quarantine
S3_CLEAN_BUCKET=rag-clean
S3_DERIVED_BUCKET=rag-derived
S3_FORCE_PATH_STYLE=true

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CONSUMER_GROUP=rag-ingestion-v1
KAFKA_AWS_MSK_IAM=false
AWS_REGION=us-east-1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=rag_chunks
QDRANT_VECTOR_SIZE=1536
QDRANT_REPLICATION_FACTOR=1

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_IAM_ENABLED=false
REDIS_IAM_USER=
REDIS_IAM_CACHE_NAME=
CACHE_VOLATILE_TTL_SECONDS=3600
CACHE_STABLE_TTL_SECONDS=86400
SEMANTIC_CACHE_THRESHOLD=0.93
CITATION_HMAC_SECRET=local-citation-secret-change-in-production

# Model provider. deterministic requires no key and is for local validation only.
MODEL_PROVIDER=deterministic
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# Reranker. lexical is lightweight; cross_encoder requires `uv sync --extra ml`.
RERANKER_PROVIDER=lexical
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# Tavily web search
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
WEB_SEARCH_ENABLED=false

# Ingestion
MAX_UPLOAD_BYTES=104857600
MAX_PDF_PAGES=5000
CHUNK_TARGET_TOKENS=450
CHUNK_MAX_TOKENS=600
CHUNK_OVERLAP_TOKENS=60
# OCR fallback. When enabled, pages whose native text extraction fails
# quality gates (text density, replacement chars, min characters) are
# re-extracted via Tesseract OCR. Requires Tesseract installed on the host.
OCR_ENABLED=false
# OCR DPI controls rendering resolution before text recognition (250-300).
OCR_DPI=300
# Tesseract language code (e.g. eng, deu, fra, chi_sim). Use + to stack: eng+deu.
OCR_LANGUAGE=eng
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Retrieval and context
SPARSE_CANDIDATES=50
DENSE_CANDIDATES=50
FUSION_CANDIDATES=20
FINAL_CONTEXT_CHUNKS=5
RRF_K=60
MMR_LAMBDA=0.7
CONTEXT_EVIDENCE_RATIO=0.65

# Optional GraphRAG
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j-local-password

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=rag-api
