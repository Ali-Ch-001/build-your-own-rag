{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["api", "frontend", "ingestionWorker", "deletionWorker", "config"],
  "properties": {
    "existingSecret": {"type": "string", "minLength": 1},
    "config": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean"]}},
    "api": {"$ref": "#/$defs/workload"},
    "frontend": {"$ref": "#/$defs/workload"},
    "ingestionWorker": {"$ref": "#/$defs/worker"},
    "deletionWorker": {"$ref": "#/$defs/worker"}
  },
  "$defs": {
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "tag": {"type": "string"},
        "digest": {"type": "string", "pattern": "^$|^sha256:[a-f0-9]{64}$|^sha256:replace-with-release-digest$"},
        "pullPolicy": {"enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "workload": {
      "type": "object",
      "required": ["image", "replicaCount", "resources"],
      "properties": {
        "image": {"$ref": "#/$defs/image"},
        "replicaCount": {"type": "integer", "minimum": 0},
        "resources": {"type": "object"}
      }
    },
    "worker": {
      "allOf": [
        {"$ref": "#/$defs/workload"},
        {
          "type": "object",
          "required": ["enabled", "command", "topic", "consumerGroup"],
          "properties": {
            "enabled": {"type": "boolean"},
            "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
            "topic": {"type": "string", "minLength": 1},
            "consumerGroup": {"type": "string", "minLength": 1}
          }
        }
      ]
    }
  }
}
